# Production secrets for docker-compose.prod.yml.
# In Coolify, set these under the resource's "Environment Variables" (mark them as secret)
# instead of committing a .env file. For plain docker compose: cp .env.production.example .env
# and fill in strong values.

# Postgres superuser password, shared by the three service datasources and the backup sidecar.
# Generate: openssl rand -base64 24
POSTGRES_PASSWORD=

# HS256 signing key for portador-service JWTs. Minimum 32 bytes.
# Generate: openssl rand -base64 48
JWT_SECRET=
